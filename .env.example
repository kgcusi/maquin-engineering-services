# PMTIS environment — copy to .env.local and fill in. NEVER commit real secrets.
# Canonical list: docs/16-tech-decisions.md §8.

# ── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
APP_TIMEZONE=Asia/Manila          # adjust to the firm
APP_CURRENCY=PHP                  # single base currency

# ── Database — Neon Postgres (Vercel Marketplace) ────────────────────────────
# DATABASE_URL must be the POOLED, transaction-capable endpoint. The app uses
# postgres-js with prepare:false against it (PgBouncer transaction mode).
# DATABASE_URL_UNPOOLED is the DIRECT endpoint, used ONLY by Drizzle Kit
# migrations. Never use the neon-http driver. See docs/16 §2.
DATABASE_URL=postgresql://neondb_owner:npg_W29cfOdSFlGp@ep-misty-fire-aovxwncb-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_UNPOOLED=

# ── Auth — Better Auth ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=kTza8tYV133QueVlTqxRMvTvpWYhnDiM6jeciDwzDtk               # generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000   # = APP_BASE_URL

# ── Email — Resend (wired in Stage 1) ────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=                       # "PMTIS <no-reply@firm.com>" on a verified domain

# ── Storage — Cloudflare R2 (wired in Stage 1) ───────────────────────────────
R2_ENDPOINT=                      # https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Cron protection (wired in Stage 1) ───────────────────────────────────────
CRON_SECRET=

# ── Seed — Stage 0 bootstrap accounts (local only; used by `pnpm db:seed`) ────
# WEBMASTER = hidden superuser (full access, never shown in user lists).
# ADMIN = normal top-level role.
SEED_WEBMASTER_EMAIL=karl@webmaster.com
SEED_WEBMASTER_PASSWORD=C68e92b11
SEED_WEBMASTER_NAME="Karl Webmaster"
SEED_ADMIN_EMAIL=admin@maquin.com
SEED_ADMIN_PASSWORD=123abc123
SEED_ADMIN_NAME="Admin"
