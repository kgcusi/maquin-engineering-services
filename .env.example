# PMTIS environment — copy to .env.local and fill in. NEVER commit real secrets.
# Canonical list: docs/16-tech-decisions.md §8.

# ── App ──────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000
APP_TIMEZONE=Asia/Manila          # adjust to the firm
APP_CURRENCY=PHP                  # single base currency

# ── Database — Neon Postgres (Vercel Marketplace) ────────────────────────────
# DATABASE_URL must be the POOLED, transaction-capable endpoint (host contains
# "-pooler"). The app uses postgres-js with prepare:false against it (PgBouncer
# transaction mode). Drizzle Kit migrations need the DIRECT endpoint — by default
# it's DERIVED from DATABASE_URL by dropping "-pooler" (see drizzle.config.ts), so
# you normally only set DATABASE_URL. Set DATABASE_URL_UNPOOLED only to override
# that derivation. Never use the neon-http driver. See docs/16 §2.
DATABASE_URL=
# DATABASE_URL_UNPOOLED=          # optional — only if the derived direct URL is wrong

# ── Auth — Better Auth ───────────────────────────────────────────────────────
BETTER_AUTH_SECRET=               # generate: openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000   # = APP_BASE_URL

# ── Email — Resend (wired in Stage 1) ────────────────────────────────────────
# Preferred: set these at runtime in System Settings → Email delivery (webmaster
# only); that's what the in-app connection test validates. These env vars remain a
# fallback for the (not-yet-wired) send path.
RESEND_API_KEY=
EMAIL_FROM=                       # "MAQUIN Engineering <no-reply@firm.com>" on a verified domain

# ── Storage — Cloudflare R2 (wired in Stage 1) ───────────────────────────────
# Used by the file-upload pipeline (client documents now; DSR photos / receipts
# later). Browser uploads go DIRECT to R2 via a presigned PUT, so the bucket needs
# CORS allowing PUT from the app origin with Content-Type + Content-Length headers.
R2_ENDPOINT=                      # https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# ── Cron protection (wired in Stage 1) ───────────────────────────────────────
CRON_SECRET=

# ── Seed — Stage 0 bootstrap accounts (local only; used by `pnpm db:seed`) ────
# WEBMASTER = hidden superuser (full access, never shown in user lists).
# ADMIN = normal top-level role.
SEED_WEBMASTER_EMAIL=
SEED_WEBMASTER_PASSWORD=
SEED_WEBMASTER_NAME=
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=
